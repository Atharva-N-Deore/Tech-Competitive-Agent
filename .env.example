# ── Model selection ──────────────────────────────────────────────────────────
# LiteLLM uses "provider/model" format. Uncomment one line, or set your own.
#
# Anthropic (cloud):
MODEL_ID=anthropic/claude-sonnet-4-6
# MODEL_ID=anthropic/claude-haiku-4-5-20251001     # faster / cheaper
#
# OpenAI (cloud):
# MODEL_ID=gpt-4o
# MODEL_ID=gpt-4o-mini
#
# Groq (cloud, free tier available):
# MODEL_ID=groq/llama3-8b-8192
# MODEL_ID=groq/llama-3.3-70b-versatile
#
# Ollama (local, no API key needed — run `ollama pull llama3.2` first):
# MODEL_ID=ollama/llama3.2
# MODEL_ID=ollama/mistral

# ── API keys ─────────────────────────────────────────────────────────────────
# Only the key for your chosen provider is required.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=       # without this: 60 req/hr; with it: 5000 req/hr
LOG_LEVEL=INFO
